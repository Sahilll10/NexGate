# ============================================================
# NexGate Management API — Environment Configuration
# ============================================================

NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0

# Frontend URL (for CORS)
PORTAL_URL=http://localhost:5173

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nexgate?retryWrites=true&w=majority
MONGODB_MAX_POOL_SIZE=15

# Redis
REDIS_URL=redis://:<password>@<host>:<port>
REDIS_TLS=false

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Admin Setup (first-time setup only)
ADMIN_EMAIL=admin@nexgate.io
ADMIN_PASSWORD=ChangeMe123!

# Cache TTLs (seconds)
API_KEY_CACHE_TTL=120
API_CONFIG_CACHE_TTL=300
