# NexGate — Root Environment Reference
# ============================================================
# Copy the relevant sections to each package's .env file:
#   packages/gateway/.env
#   packages/api/.env
#   packages/portal/.env
#
# For local dev, run: docker compose up -d
# Then use the values in the LOCAL DEV section.
# ============================================================

# ─── LOCAL DEV (docker-compose) ───────────────────────────────
MONGODB_URI=mongodb://nexgate:nexgate_dev_password@localhost:27017/nexgate?authSource=admin
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ─── PRODUCTION (Atlas + Upstash) ─────────────────────────────
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nexgate?retryWrites=true&w=majority
# REDIS_URL=rediss://:<password>@<host>.upstash.io:<port>
# REDIS_TLS=true

# ─── SHARED ───────────────────────────────────────────────────
JWT_SECRET=please_change_this_to_a_random_32_char_string_minimum

# ─── GATEWAY SPECIFIC ─────────────────────────────────────────
GATEWAY_PORT=3000
NODE_ENV=development
API_KEY_HEADER=x-nexgate-key
DEFAULT_RATE_LIMIT_ALGORITHM=sliding_window_log
DEFAULT_RATE_LIMIT_MAX_REQUESTS=100
DEFAULT_RATE_LIMIT_WINDOW_MS=60000
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=30000
LOG_QUEUE_NAME=nexgate:logs

# ─── MANAGEMENT API SPECIFIC ──────────────────────────────────
API_PORT=4000
PORTAL_URL=http://localhost:5173

# ─── PORTAL SPECIFIC ──────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api
