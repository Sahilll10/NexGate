# ============================================================
# NexGate Gateway — Environment Configuration
# Copy this file to .env and fill in real values
# ============================================================

# Server
NODE_ENV=development
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nexgate?retryWrites=true&w=majority
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# Redis (Upstash or Aiven — use REDIS_URL for Upstash HTTP, REDIS_TCP_URL for standard TCP)
REDIS_URL=redis://:<password>@<host>:<port>
# For Upstash: use the TCP/TLS endpoint for BullMQ (BullMQ needs TCP, not HTTP)
REDIS_TLS=true

# API Config Cache TTL (seconds)
API_CONFIG_CACHE_TTL=300
API_KEY_CACHE_TTL=120

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=30000
CIRCUIT_BREAKER_HALF_OPEN_REQUESTS=3

# BullMQ
LOG_QUEUE_NAME=nexgate:logs
LOG_QUEUE_CONCURRENCY=10
LOG_QUEUE_MAX_JOBS=50000

# Rate Limit Defaults
DEFAULT_RATE_LIMIT_ALGORITHM=sliding_window_log
DEFAULT_RATE_LIMIT_WINDOW_MS=60000
DEFAULT_RATE_LIMIT_MAX_REQUESTS=100

# Security
API_KEY_HEADER=x-nexgate-key
HASH_ALGORITHM=sha256

# Logging
LOG_LEVEL=info
